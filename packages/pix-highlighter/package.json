{
  "name": "@pix-galaxy/pix-highlighter",
  "version": "0.0.1",
  "description": "Syntax-highlighting Web Component for the pix-galaxy suite.",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "node ../../scripts/_clean.js pix-highlighter",
    "build": "node ../../scripts/_build-package.js pix-highlighter",
    "test": "pnpm docs:build && node --test --import ./tests/_register-loader.mjs tests/index.js",
    "typecheck": "pnpm exec tsc -p tsconfig.types.json --noEmit",
    "validate": "node ../../scripts/_validate-package.js pix-highlighter",
    "docs:build": "node ../../scripts/_build-docs.js pix-highlighter",
    "docs:serve": "node ../../scripts/_serve-docs.js pix-highlighter"
  },
  "devDependencies": {
    "@pix-galaxy/shared": "workspace:*"
  },
  "dependencies": {}
}
