{
  "name": "@pix-galaxy/pix-card",
  "version": "0.1.0",
  "description": "Accessible card Web Component. Zero runtime dependencies.",
  "type": "module",
  "sideEffects": [
    "./dist/index.css"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./css": "./dist/index.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "node ../../scripts/clean.js pix-card",
    "build": "node ../../scripts/build-package.js pix-card",
    "test": "node --test test/*.test.js",
    "typecheck": "pnpm exec tsc -p tsconfig.types.json --noEmit",
    "validate": "node ../../scripts/validate-package.js pix-card",
    "docs:build": "node ../../scripts/build-docs.js pix-card"
  },
  "dependencies": {}
}
