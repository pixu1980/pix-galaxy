{
  "name": "@pix-galaxy/pix-color-scheme-switcher",
  "version": "0.0.1",
  "description": "Persisted light/dark/system color scheme switcher Web Component",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "node ../../scripts/_clean.js pix-color-scheme-switcher",
    "build": "node ../../scripts/_build-package.js pix-color-scheme-switcher",
    "test": "node --test --import ./tests/_register-loader.mjs tests/index.js",
    "typecheck": "pnpm exec tsc -p tsconfig.types.json --noEmit",
    "validate": "node ../../scripts/_validate-package.js pix-color-scheme-switcher",
    "docs:build": "node ../../scripts/_build-docs.js pix-color-scheme-switcher",
    "docs:serve": "node ../../scripts/_serve-docs.js pix-color-scheme-switcher"
  },
  "devDependencies": {
    "@pix-galaxy/shared": "workspace:*"
  },
  "dependencies": {}
}
