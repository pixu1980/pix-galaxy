{
  "name": "@pix-galaxy/pix-design-system",
  "version": "0.0.1",
  "description": "Native CSS design system package for the pix-galaxy monorepo.",
  "type": "module",
  "sideEffects": [
    "./dist/index.css"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./css": "./dist/index.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "node ../../scripts/_clean.js pix-design-system",
    "build": "node ../../scripts/_build-package.js pix-design-system",
    "test": "node --test tests/index.js",
    "typecheck": "pnpm exec tsc -p tsconfig.types.json --noEmit",
    "validate": "node ../../scripts/_validate-package.js pix-design-system",
    "docs:build": "node ../../scripts/_build-docs.js pix-design-system",
    "docs:serve": "node ../../scripts/_serve-docs.js pix-design-system"
  },
  "dependencies": {}
}
